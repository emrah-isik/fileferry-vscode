{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FileFerry Configuration",
  "description": "Deployment server configuration for the FileFerry VSCode extension",
  "type": "object",
  "properties": {
    "defaultServer": {
      "type": "string",
      "description": "ID of the default server used for Alt+U uploads"
    },
    "servers": {
      "type": "array",
      "description": "List of deployment server profiles",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "host", "port", "username", "authMethod", "mappings"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this server (auto-generated)"
          },
          "name": {
            "type": "string",
            "description": "Display name shown in the UI (e.g. 'Production', 'Staging')"
          },
          "type": {
            "type": "string",
            "enum": ["sftp", "ftp"],
            "description": "Connection protocol"
          },
          "host": {
            "type": "string",
            "description": "Server hostname or IP address"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "default": 22,
            "description": "SSH/SFTP port (default: 22)"
          },
          "username": {
            "type": "string",
            "description": "Login username on the remote server"
          },
          "authMethod": {
            "type": "string",
            "enum": ["password", "key", "agent"],
            "description": "Authentication method. Passwords and passphrases are stored in the OS keychain, never in this file."
          },
          "privateKeyPath": {
            "type": "string",
            "description": "Path to SSH private key file. Use ~ for home directory. Only required when authMethod is 'key'."
          },
          "mappings": {
            "type": "array",
            "description": "Local-to-remote path mappings. More specific paths take priority.",
            "items": {
              "type": "object",
              "required": ["localPath", "remotePath"],
              "properties": {
                "localPath": {
                  "type": "string",
                  "description": "Local path relative to workspace root. Use '/' for the whole project."
                },
                "remotePath": {
                  "type": "string",
                  "description": "Absolute path on the remote server."
                }
              },
              "additionalProperties": false
            },
            "minItems": 1
          },
          "excludedPaths": {
            "type": "array",
            "description": "Glob patterns for files/folders to never upload (e.g. 'node_modules', '*.log', '.env')",
            "items": {
              "type": "string"
            },
            "default": ["node_modules", ".git", "*.log", ".env", ".DS_Store"]
          }
        },
        "additionalProperties": false,
        "if": {
          "properties": { "authMethod": { "const": "key" } }
        },
        "then": {
          "required": ["privateKeyPath"]
        }
      }
    }
  },
  "required": ["servers"],
  "additionalProperties": false
}
