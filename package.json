{
  "name": "fileferry",
  "displayName": "FileFerry",
  "description": "Deploy git-changed files to remote servers with precision. Select, confirm, upload.",
  "version": "0.4.0",
  "publisher": "esidevlabs",
  "icon": "resources/icon.png",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/emrah-isik/fileferry-vscode"
  },
  "keywords": [
    "sftp",
    "deploy",
    "git",
    "upload",
    "ssh",
    "ftp"
  ],
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fileferry.uploadSelected",
        "title": "FileFerry: Upload"
      },
      {
        "command": "fileferry.openSettings",
        "title": "FileFerry: Deployment Settings",
        "icon": "$(gear)"
      },
      {
        "command": "fileferry.switchServer",
        "title": "FileFerry: Switch Server"
      },
      {
        "command": "fileferry.openCredentials",
        "title": "FileFerry: Manage SSH Credentials"
      },
      {
        "command": "fileferry.resetConfirmations",
        "title": "FileFerry: Reset Upload Confirmations"
      },
      {
        "command": "fileferry.showRemoteDiff",
        "title": "FileFerry: Compare with Remote"
      },
      {
        "command": "fileferry.remoteBrowser.refresh",
        "title": "FileFerry: Refresh Remote Browser",
        "icon": "$(refresh)"
      },
      {
        "command": "fileferry.remoteBrowser.openFile",
        "title": "FileFerry: Open Remote File"
      },
      {
        "command": "fileferry.remoteBrowser.navigateTo",
        "title": "FileFerry: Go to Remote Path",
        "icon": "$(folder-opened)"
      },
      {
        "command": "fileferry.remoteBrowser.disconnect",
        "title": "FileFerry: Disconnect Remote Browser"
      },
      {
        "command": "fileferry.remoteBrowser.copyPath",
        "title": "Copy Remote Path"
      },
      {
        "command": "fileferry.remoteBrowser.downloadToWorkspace",
        "title": "Download to Workspace"
      },
      {
        "command": "fileferry.remoteBrowser.diffWithLocal",
        "title": "Compare with Local"
      },
      {
        "command": "fileferry.remoteBrowser.delete",
        "title": "Delete from Server"
      },
      {
        "command": "fileferry.servers.setDefault",
        "title": "FileFerry: Set as Default Server"
      },
      {
        "command": "fileferry.servers.refresh",
        "title": "FileFerry: Refresh Servers",
        "icon": "$(refresh)"
      },
      {
        "command": "fileferry.servers.editServer",
        "title": "Edit Server"
      },
      {
        "command": "fileferry.servers.testConnection",
        "title": "Test Connection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fileferry-remote",
          "title": "FileFerry",
          "icon": "resources/icon-activitybar.svg"
        }
      ]
    },
    "views": {
      "fileferry-remote": [
        {
          "id": "fileferry.serversView",
          "name": "Servers"
        },
        {
          "id": "fileferry.remoteBrowser",
          "name": "Remote Files",
          "contextualTitle": "FileFerry Remote Browser"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "fileferry.serversView",
        "contents": "No servers configured yet.\n[Add Server](command:fileferry.openSettings)\n[Add SSH Credential](command:fileferry.openCredentials)"
      },
      {
        "view": "fileferry.remoteBrowser",
        "contents": "Browse files on your remote server.\n[Set Up a Server](command:fileferry.openSettings)",
        "when": "!fileferry.hasServers"
      }
    ],
    "menus": {
      "scm/resourceState/context": [
        {
          "command": "fileferry.uploadSelected",
          "group": "fileferry@1"
        },
        {
          "command": "fileferry.showRemoteDiff",
          "group": "fileferry@2"
        }
      ],
      "explorer/context": [
        {
          "command": "fileferry.uploadSelected",
          "when": "resourceScheme == file",
          "group": "fileferry@1"
        },
        {
          "command": "fileferry.showRemoteDiff",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "fileferry@2"
        }
      ],
      "view/title": [
        {
          "command": "fileferry.remoteBrowser.navigateTo",
          "when": "view == fileferry.remoteBrowser",
          "group": "navigation"
        },
        {
          "command": "fileferry.remoteBrowser.refresh",
          "when": "view == fileferry.remoteBrowser",
          "group": "navigation"
        },
        {
          "command": "fileferry.openSettings",
          "when": "view == fileferry.serversView",
          "group": "navigation"
        },
        {
          "command": "fileferry.servers.refresh",
          "when": "view == fileferry.serversView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "fileferry.remoteBrowser.refresh",
          "when": "view == fileferry.remoteBrowser && viewItem == remoteDirectory",
          "group": "inline"
        },
        {
          "command": "fileferry.remoteBrowser.downloadToWorkspace",
          "when": "view == fileferry.remoteBrowser && viewItem == remoteFile",
          "group": "1_transfer"
        },
        {
          "command": "fileferry.remoteBrowser.diffWithLocal",
          "when": "view == fileferry.remoteBrowser && viewItem == remoteFile",
          "group": "1_transfer"
        },
        {
          "command": "fileferry.remoteBrowser.delete",
          "when": "view == fileferry.remoteBrowser && viewItem =~ /^remote(File|Directory)$/",
          "group": "3_destructive"
        },
        {
          "command": "fileferry.remoteBrowser.copyPath",
          "when": "view == fileferry.remoteBrowser",
          "group": "2_actions"
        },
        {
          "command": "fileferry.servers.setDefault",
          "when": "view == fileferry.serversView && viewItem == server-inactive",
          "group": "1_switch"
        },
        {
          "command": "fileferry.servers.editServer",
          "when": "view == fileferry.serversView",
          "group": "2_manage"
        },
        {
          "command": "fileferry.servers.testConnection",
          "when": "view == fileferry.serversView",
          "group": "2_manage"
        }
      ],
      "commandPalette": [
        {
          "command": "fileferry.uploadSelected",
          "when": "false"
        },
        {
          "command": "fileferry.showRemoteDiff",
          "when": "false"
        },
        {
          "command": "fileferry.remoteBrowser.openFile",
          "when": "false"
        },
        {
          "command": "fileferry.servers.setDefault",
          "when": "false"
        },
        {
          "command": "fileferry.servers.editServer",
          "when": "false"
        },
        {
          "command": "fileferry.servers.testConnection",
          "when": "false"
        },
        {
          "command": "fileferry.remoteBrowser.copyPath",
          "when": "false"
        },
        {
          "command": "fileferry.remoteBrowser.downloadToWorkspace",
          "when": "false"
        },
        {
          "command": "fileferry.remoteBrowser.diffWithLocal",
          "when": "false"
        },
        {
          "command": "fileferry.remoteBrowser.delete",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "fileferry.uploadSelected",
        "key": "alt+u",
        "when": "focusedView == workbench.scm"
      },
      {
        "command": "fileferry.showRemoteDiff",
        "key": "alt+p",
        "when": "focusedView == workbench.scm"
      },
      {
        "command": "fileferry.uploadSelected",
        "key": "alt+u",
        "when": "editorTextFocus"
      },
      {
        "command": "fileferry.showRemoteDiff",
        "key": "alt+p",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "FileFerry",
      "properties": {
        "fileferry.defaultServer": {
          "type": "string",
          "description": "Name of the default deployment server"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.vscode/fileferry.json",
        "url": "./schema/fileferry-schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "minimatch": "^10.2.4",
    "ssh2-sftp-client": "^12.1.1"
  }
}
